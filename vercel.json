{
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/branding/(.*)",
      "headers": {
        "cache-control": "no-store"
      },
      "dest": "/branding/$1"
    },
    {
      "src": "/(.*)",
      "headers": {
        "cache-control": "no-store"
      },
      "dest": "/index.html"
    }
  ]
}
